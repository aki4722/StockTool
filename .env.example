# Copy this file to .env and fill in real values.
# Never commit .env to git.

# ── Anthropic (required for BBS sentiment analysis) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_HOST=mysql          # use "mysql" for docker-compose, hostname for Render
MYSQL_PORT=3306
MYSQL_USER=stocktool
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=stocktool_bbs

# ── MySQL root (docker-compose only) ─────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootchangeme
